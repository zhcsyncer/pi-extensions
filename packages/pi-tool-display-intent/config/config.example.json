{
  "debug": false,
  "registerToolOverrides": {
    "read": true,
    "grep": true,
    "find": true,
    "ls": true,
    "bash": true,
    "edit": true,
    "write": true
  },
  "displaySummary": {
    "enabled": true,
    "required": true,
    "language": "auto",
    "showInTui": true,
    "maxLength": 96
  },
  "customToolOverrides": {
    "ide_find_symbol": {
      "enabled": false,
      "kind": "generic",
      "outputMode": "summary"
    },
    "custom_mcp_gateway": {
      "enabled": false,
      "kind": "mcp",
      "outputMode": "summary"
    }
  },
  "enableNativeUserMessageBox": true,
  "readOutputMode": "hidden",
  "searchOutputMode": "hidden",
  "mcpOutputMode": "hidden",
  "previewLines": 8,
  "expandedPreviewMaxLines": 4000,
  "bashOutputMode": "opencode",
  "bashCollapsedLines": 10,
  "diffViewMode": "auto",
  "diffIndicatorMode": "bars",
  "diffSplitMinWidth": 120,
  "diffCollapsedLines": 24,
  "diffWordWrap": true,
  "showTruncationHints": false,
  "showRtkCompactionHints": false
}
