{
  "$schema": "https://raw.githubusercontent.com/zhcsyncer/pi-extensions/main/packages/pi-tool-display-intent/config/config.schema.json",
  "version": 2,
  "intent": {
    "language": "zh-CN"
  },
  "toolCalls": {
    "frame": "claude"
  },
  "results": {
    "profile": "minimal",
    "previewRows": 10,
    "overrides": {
      "read": "summary",
      "search": "preview",
      "bash": {
        "mode": "inline",
        "collapsedRows": 12
      }
    }
  },
  "diff": {
    "layout": "auto",
    "indicators": "bars"
  },
  "transcript": {
    "userMessage": "boxed",
    "thinkingLabel": true
  },
  "tools": {
    "custom": {
      "web_search": {
        "enabled": true,
        "renderer": "generic",
        "result": "summary"
      },
      "custom_mcp_gateway": {
        "enabled": false,
        "renderer": "mcp",
        "result": "summary"
      }
    }
  },
  "advanced": {
    "expandedLineLimit": 500,
    "truncationHints": false,
    "rtkCompactionHints": false,
    "debug": false
  }
}
