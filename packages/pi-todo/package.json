{
  "name": "@zhcsyncer/pi-todo",
  "version": "0.1.0",
  "private": true,
  "description": "Internal fork of rpiv-todo for the @zhcsyncer/pi-extensions bundle.",
  "keywords": [
    "pi-package",
    "pi-extension",
    "todo"
  ],
  "type": "module",
  "license": "MIT",
  "author": "juicesharp",
  "contributors": [
    "zhcsyncer (fork maintainer)"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhcsyncer/pi-extensions.git",
    "directory": "packages/pi-todo"
  },
  "homepage": "https://github.com/zhcsyncer/pi-extensions/tree/main/packages/pi-todo#readme",
  "bugs": {
    "url": "https://github.com/zhcsyncer/pi-extensions/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "check": "pnpm typecheck && pnpm test"
  },
  "files": [
    "config.ts",
    "index.ts",
    "locales/",
    "todo.ts",
    "todo-overlay.ts",
    "state/",
    "tool/",
    "view/",
    "README.md",
    "LICENSE",
    "UPSTREAM_LICENSE",
    "UPSTREAM_README.md",
    "UPSTREAM_CHANGELOG.md",
    "UPSTREAM_SOURCE.md"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "peerDependencies": {
    "@juicesharp/rpiv-i18n": "*",
    "@earendil-works/pi-ai": "^0.80.0",
    "@earendil-works/pi-coding-agent": "^0.80.0",
    "@earendil-works/pi-tui": "^0.80.0",
    "typebox": "^1.1.24"
  },
  "peerDependenciesMeta": {
    "@juicesharp/rpiv-i18n": {
      "optional": true
    }
  },
  "dependencies": {
    "@juicesharp/rpiv-config": "1.20.0"
  },
  "devDependencies": {
    "@juicesharp/rpiv-test-utils": "workspace:*",
    "@types/node": "25.6.0",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  }
}
