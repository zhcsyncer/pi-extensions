{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@earendil-works/pi-ai": ["./node_modules/@earendil-works/pi-ai/dist/compat.d.ts"]
    },
    "noEmit": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "strict": true,
    "types": ["node"]
  },
  "include": ["index.ts", "test/**/*.ts"]
}
