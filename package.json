{
  "name": "@zhcsyncer/pi-extensions",
  "version": "0.1.4",
  "description": "A collection of Pi extensions by zhcsyncer.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhcsyncer/pi-extensions.git"
  },
  "homepage": "https://github.com/zhcsyncer/pi-extensions#readme",
  "bugs": {
    "url": "https://github.com/zhcsyncer/pi-extensions/issues"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-extensions"
  ],
  "license": "MIT",
  "type": "module",
  "files": [
    "packages/*/extensions/**/*.ts",
    "packages/*/extensions/**/*.js",
    "packages/*/src/**/*.ts",
    "packages/*/src/**/*.js",
    "packages/*/src/**/*.d.ts",
    "packages/*/README*.md",
    "packages/*/LICENSE",
    "packages/*/UPSTREAM_LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "changeset": "changeset",
    "version-packages": "changeset version && node scripts/sync-release-version.mjs",
    "release": "changeset publish",
    "check": "pnpm check:smoke && pnpm check:pack",
    "check:smoke": "pi --no-extensions -e . --list-models __pi_release_check__ && pi --no-extensions -e ./packages/pi-recap --list-models __pi_release_check__ && pi --no-extensions -e ./packages/pi-tool-display-intent --list-models __pi_release_check__",
    "check:pack": "npm pack --dry-run . && npm pack --dry-run ./packages/pi-recap && npm pack --dry-run ./packages/pi-tool-display-intent"
  },
  "pi": {
    "extensions": [
      "./packages/pi-recap/extensions/recap.ts",
      "./packages/pi-tool-display-intent/extensions/tool-display-intent.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0"
  },
  "packageManager": "pnpm@11.11.0"
}
