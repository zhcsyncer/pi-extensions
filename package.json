{
  "name": "@zhcsyncer/pi-extensions",
  "version": "0.1.2",
  "description": "A collection of Pi extensions by zhcsyncer.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhcsyncer/pi-extensions.git"
  },
  "homepage": "https://github.com/zhcsyncer/pi-extensions#readme",
  "bugs": {
    "url": "https://github.com/zhcsyncer/pi-extensions/issues"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-extensions"
  ],
  "license": "MIT",
  "type": "module",
  "files": [
    "packages/*/extensions/**/*.ts",
    "packages/*/extensions/**/*.js"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "changeset": "changeset",
    "version-packages": "changeset version && node scripts/sync-release-version.mjs",
    "release": "changeset publish",
    "check": "pnpm check:smoke && pnpm check:pack",
    "check:smoke": "pi -e . --list-models __pi_release_check__ && pi -e ./packages/pi-recap --list-models __pi_release_check__",
    "check:pack": "npm pack --dry-run . && npm pack --dry-run ./packages/pi-recap"
  },
  "pi": {
    "extensions": [
      "./packages/pi-recap/extensions/recap.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0"
  },
  "packageManager": "pnpm@11.11.0"
}
